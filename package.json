{
  "name": "ai-post-management",
  "version": "1.0.0",
  "description": "AI Post Management Platform - Monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=admin-panel",
    "build": "npm run build --workspaces",
    "build:frontend": "npm run build --workspace=admin-panel",
    "install:all": "npm install"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
