# Supabase Configuration
# Get keys from: Project Settings → API Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# Stripe Configuration
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx

# Email Configuration (SMTP)
# For Gmail: smtp.gmail.com, port 587
# For SendGrid: smtp.sendgrid.net, port 587
# For AWS SES: email-smtp.region.amazonaws.com, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Frontend URLs (also used for CORS allowlist)
FRONTEND_URL=http://localhost:5173          # Admin panel
CUSTOMER_APP_URL=http://localhost:5174       # Customer app
# Optional: comma-separated extra origins, e.g. https://app.example.com,https://staging.example.com
# CORS_ORIGINS=

# Image Generation — DB-driven provider (migrations 016–017) + encrypted keys (admin /admin/image-generation/*).
# 017 adds provider_models (JSONB): per-provider model ids editable via PUT /admin/image-generation/settings;
# when a key is set for a provider it overrides the env defaults below for that provider.
# Master key for AES-256-GCM (32 bytes base64 OR 64 hex chars). Required to store or decrypt provider API keys:
# openssl rand -base64 32
# PROVIDER_KEYS_MASTER_KEY=
# OpenAI when active_provider=openai (used if provider_models.openai is unset):
# OPENAI_IMAGE_MODEL=dall-e-3
# When product +/or logo HTTPS URLs are present, the server calls /v1/images/edits; if the configured
# generations model is not gpt-image*, this model id is used for edits (default gpt-image-1):
# OPENAI_IMAGE_EDIT_MODEL=gpt-image-1
# Google Imagen (Gemini API key from https://aistudio.google.com/apikey) when active_provider=google.
# Default model if provider_models.google unset: imagen-4.0-generate-001
# GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image
# Optional Imagen safety: dont_allow | allow_adult | allow_all (region restrictions apply)
# GOOGLE_IMAGEN_PERSON_GENERATION=allow_adult
#
# xAI Grok Imagine when active_provider=grok (https://console.x.ai/)
# GROK_IMAGE_MODEL=grok-imagine-image
# GROK_IMAGE_RESOLUTION=1k
# Optional override if xAI changes host: XAI_API_BASE_URL=https://api.x.ai/v1
#
# Legacy HTTP gateway (still takes precedence over DB when all set):
# IMAGE_GENERATION_USE_EXTERNAL=true
# IMAGE_GENERATION_API_URL=https://your-provider.example.com
# IMAGE_GENERATION_API_KEY=
# Optional: override mock placeholder URL (default is a fixed picsum seed)
# IMAGE_GENERATION_MOCK_IMAGE_URL=https://example.com/your-placeholder.png
IMAGE_GENERATION_USE_EXTERNAL=
IMAGE_GENERATION_API_URL=
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_MOCK_IMAGE_URL=
# Agent-style prompt orchestration (see packages/backend/BACKEND_CHECKLIST.md Phase E)
# IMAGE_GENERATION_AGENT_ENABLED=true
# GOOGLE_AI_API_KEY=  # or Vertex — when implementing E3/E4

# Server
PORT=3000

# Async image generation (202 + WebSocket + BullMQ). When REDIS_URL is set, POST /api/customer/generate
# returns 202 with jobId; connect Socket.io (same host, path /socket.io). Send the Supabase access JWT as
# auth.token (socket.io-client), or Authorization: Bearer <jwt> on the handshake (Postman), or query token / access_token.
# Listen for generation.completed / generation.failed, or poll GET /api/customer/generation-jobs/:jobId.
# Omit REDIS_URL for synchronous 201 (dev-friendly).
#
# Start Redis: from repo root, run: docker compose up -d redis
# REDIS_URL=redis://localhost:6379
# Optional: force sync mode even if Redis is set
# IMAGE_GENERATION_ASYNC=false
# Optional BullMQ namespace if sharing Redis with other apps
# BULLMQ_PREFIX=bull:nexus
# Parallel generation jobs per server (default 4)
# IMAGE_GENERATION_CONCURRENCY=4
