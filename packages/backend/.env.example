# Supabase Configuration
# Get keys from: Project Settings → API Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# Stripe Configuration
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx

# Email Configuration (SMTP)
# For Gmail: smtp.gmail.com, port 587
# For SendGrid: smtp.sendgrid.net, port 587
# For AWS SES: email-smtp.region.amazonaws.com, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Frontend URLs
FRONTEND_URL=http://localhost:5173          # Admin panel
CUSTOMER_APP_URL=http://localhost:5174       # Customer app

# Image Generation — mock by default (single dummy image). Enable real API when ready:
# IMAGE_GENERATION_USE_EXTERNAL=true
# IMAGE_GENERATION_API_URL=https://your-provider.example.com
# IMAGE_GENERATION_API_KEY=
# Optional: override mock placeholder URL (default is a fixed picsum seed)
# IMAGE_GENERATION_MOCK_IMAGE_URL=https://example.com/your-placeholder.png
IMAGE_GENERATION_USE_EXTERNAL=
IMAGE_GENERATION_API_URL=
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_MOCK_IMAGE_URL=

# Server
PORT=3000
